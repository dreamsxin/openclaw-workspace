# ─── LLM ───
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# ─── Auth ───
# Comma-separated API keys for accessing the agent API
# Leave empty to auto-generate one on startup
API_KEYS=

# ─── Server ───
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ─── Security ───
SAFETY_LEVEL=balanced

# ─── CORS ───
# Comma-separated origins, or * for all
CORS_ORIGINS=*

# ─── File Access ───
# Comma-separated allowed directories for file_ops tool
ALLOWED_PATHS=/tmp/agent_work
