<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#667eea">
  <meta name="description" content="元素卡片记忆游戏 - 通过游戏学习化学元素">
  <title>🃏 元素卡片记忆游戏</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cards.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <div class="container">
    <header>
      <h1>🃏 元素卡片记忆游戏</h1>
      <p class="subtitle">翻牌匹配 · 学习电子结构 · 记忆化合价</p>
    </header>

    <div class="game-controls">
      <a href="/" class="btn btn-secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">◀ 周期表探索</a>
      <a href="/experiments" class="btn btn-primary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">🧪 化学实验 ▶</a>
      <a href="/molecule" class="btn btn-primary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">🧩 分子消消乐 ▶</a>
      <div class="game-info">
        <span class="score">得分：<span id="scoreValue">0</span></span>
        <span class="moves">步数：<span id="movesValue">0</span></span>
        <span class="timer">时间：<span id="timerValue">00:00</span></span>
      </div>
    </div>

    <!-- 游戏模式选择 -->
    <div id="gameModeSelect" class="mode-select">
      <h3>选择游戏模式</h3>
      <div class="mode-options">
        <button class="mode-btn" data-mode="symbol-name">
          <span class="mode-icon">🔤</span>
          <span class="mode-title">符号 ↔ 名称</span>
          <span class="mode-desc">匹配元素符号和中文名</span>
        </button>
        <button class="mode-btn" data-mode="symbol-config">
          <span class="mode-icon">⚛️</span>
          <span class="mode-title">符号 ↔ 电子排布</span>
          <span class="mode-desc">匹配符号和电子壳层结构</span>
        </button>
        <button class="mode-btn" data-mode="symbol-valence">
          <span class="mode-icon">💫</span>
          <span class="mode-title">符号 ↔ 化合价</span>
          <span class="mode-desc">匹配符号和常见化合价</span>
        </button>
      </div>

      <!-- 卡片数量选择 -->
      <div class="grid-size-select">
        <h3>📐 选择难度（卡片数量）</h3>
        <div class="grid-options">
          <button class="grid-btn" data-grid="2">
            <span class="grid-icon">2×2</span>
            <span class="grid-desc">4 张卡片<br>入门</span>
          </button>
          <button class="grid-btn selected" data-grid="4">
            <span class="grid-icon">4×4</span>
            <span class="grid-desc">16 张卡片<br>标准</span>
          </button>
          <button class="grid-btn" data-grid="6">
            <span class="grid-icon">6×6</span>
            <span class="grid-desc">36 张卡片<br>困难</span>
          </button>
          <button class="grid-btn" data-grid="8">
            <span class="grid-icon">8×8</span>
            <span class="grid-desc">64 张卡片<br>专家</span>
          </button>
        </div>
      </div>
    </div>

    <!-- 游戏卡片区域 -->
    <div id="gameBoard" class="game-board hidden">
      <!-- 卡片由 JS 动态生成 -->
    </div>

    <!-- 游戏结束弹窗 -->
    <div id="gameOver" class="modal hidden">
      <div class="modal-content">
        <h2>🎉 游戏结束！</h2>
        <div class="final-stats">
          <p>得分：<span id="finalScore" class="stat-value">0</span></p>
          <p>步数：<span id="finalMoves" class="stat-value">0</span></p>
          <p>用时：<span id="finalTime" class="stat-value">00:00</span></p>
        </div>
        <div class="stars" id="starsDisplay">
          <span>⭐</span><span>⭐</span><span>⭐</span>
        </div>
        <button id="playAgain" class="btn btn-primary">再玩一次</button>
        <button id="backToMenu" class="btn btn-secondary">返回菜单</button>
      </div>
    </div>
  </div>

  <script type="module" src="/js/cards.js"></script>
</body>
</html>
