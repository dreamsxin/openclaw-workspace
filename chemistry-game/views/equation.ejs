<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>💥 方程式大爆炸</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/equation.css">
</head>
<body>
  <div class="game-container">
    <!-- 顶部信息 -->
    <div class="game-header">
      <div class="nav-links">
        <a href="/" class="nav-btn">◀ 返回</a>
      </div>
      <div class="game-stats">
        <div class="stat-item">
          <span class="stat-label">得分</span>
          <span class="stat-value" id="scoreValue">0</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">连击</span>
          <span class="stat-value" id="comboValue">x0</span>
        </div>
        <div class="stat-item">
          <span class="stat-label">关卡</span>
          <span class="stat-value" id="levelValue">1</span>
        </div>
      </div>
    </div>

    <!-- 倒计时和炸弹 -->
    <div class="bomb-section">
      <div class="bomb-container" id="bombContainer">
        <canvas id="bombCanvas"></canvas>
      </div>
      <div class="timer-display">
        <span class="timer-value" id="timerValue">30</span>
        <span class="timer-label">秒</span>
      </div>
    </div>

    <!-- 题目区域 -->
    <div class="question-section">
      <div class="question-type" id="questionType">补全方程式</div>
      <div class="equation-display" id="equationDisplay">
        <canvas id="equationCanvas"></canvas>
      </div>
      <div class="question-hint" id="questionHint">选择正确的选项完成方程式</div>
    </div>

    <!-- 选项区域 -->
    <div class="options-section">
      <div class="options-grid" id="optionsGrid">
        <!-- Canvas 绘制选项 -->
        <canvas id="optionsCanvas"></canvas>
      </div>
    </div>

    <!-- 游戏结束弹窗 -->
    <div id="gameOverModal" class="modal hidden">
      <div class="modal-content gameover-content">
        <h2 id="gameOverTitle">💥 时间到！</h2>
        <div id="finalScore" class="final-score"></div>
        <button id="playAgainBtn" class="btn btn-primary btn-large">🔄 再玩一次</button>
      </div>
    </div>

    <!-- 开始界面 -->
    <div id="startScreen" class="start-screen">
      <div class="start-content">
        <h1>💥 方程式大爆炸</h1>
        <p class="start-subtitle">在炸弹爆炸前选出正确答案！</p>
        <div class="start-rules">
          <div class="rule-item">⏱️ 每题 30 秒倒计时</div>
          <div class="rule-item">🧪 补全化学方程式</div>
          <div class="rule-item">🔥 连击获得额外分数</div>
          <div class="rule-item">❌ 答错减 10 秒，超时游戏结束</div>
        </div>
        <button id="startBtn" class="btn btn-primary btn-large">🚀 开始游戏</button>
      </div>
    </div>
  </div>

  <script type="module" src="/js/equation.js"></script>
</body>
</html>
