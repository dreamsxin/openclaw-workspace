# EditorConfig 帮助维护不同编辑器和 IDE 之间的编码风格一致性
# 官网：https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.css]
indent_size = 2

[*.js]
indent_size = 2

[*.ejs]
indent_size = 2

[*.{js,css}]
indent_size = 2
